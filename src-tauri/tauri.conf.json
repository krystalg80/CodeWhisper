{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeWhisper",
  "version": "0.1.0",
  "identifier": "com.codewhisper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CodeWhisper",
        "width": 420,
        "height": 680,
        "minWidth": 320,
        "minHeight": 480,
        "maxWidth": 600,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": false,
        "x": 20,
        "y": 80,
        "label": "main"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "CodeWhisper"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "AI-powered coding interview coach",
    "longDescription": "CodeWhisper is a local AI coding interview coach that uses the Socratic method to guide you — never giving you the answer, always helping you find it.",
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {
    "store": {
      "autoSave": 300
    }
  }
}
