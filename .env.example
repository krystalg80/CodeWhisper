# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Anthropic API (users enter this in-app — only needed for dev testing)
# VITE_CLAUDE_API_KEY=sk-ant-...

# Supabase (for auth + license validation)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (only needed for the Supabase Edge Functions, not the frontend directly)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# STRIPE_PRICE_ID_PRO_LIFETIME=price_...
